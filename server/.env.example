# Server Configuration
PORT=3000

# Node Environment
# Possible values: development, production, test
NODE_ENV=development

# Google Gemini API Configuration
# Get your API key from https://makersuite.google.com/app/apikey
# REQUIRED: application will not start without this
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# JWT Configuration
# REQUIRED: use a long random string (e.g. openssl rand -hex 64)
JWT_SECRET=change_this_to_a_strong_random_secret

# CORS Configuration
# Set to your frontend URL in production
CORS_ORIGIN=http://localhost:5173

# Frontend URL (used in verification and password-reset email links)
# REQUIRED in production — must point to your deployed frontend
CLIENT_URL=http://localhost:5173

# Email Configuration
# Leave EMAIL_USER and EMAIL_PASS blank in development to auto-create an Ethereal test account
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=PrepMate <noreply@prepmate.com>
SUPPORT_EMAIL=support@prepmate.com

# Optional: Rate Limiting
# RATE_LIMIT_TTL=60
# RATE_LIMIT_MAX=100
