# Server Configuration
PORT=3000

# Node Environment
# Possible values: development, production, test
NODE_ENV=development

# Google Gemini API Configuration
# Get your API key from https://makersuite.google.com/app/apikey
# REQUIRED: application will not start without this
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# JWT Configuration
# REQUIRED: use a long random string (e.g. openssl rand -hex 64)
JWT_SECRET=change_this_to_a_strong_random_secret

# CORS Configuration
# Set to your frontend URL in production
CORS_ORIGIN=http://localhost:5173

# Frontend URL (used in verification and password-reset email links)
# REQUIRED in production — must point to your deployed frontend
CLIENT_URL=http://localhost:5173

# Email Configuration
# Use Gmail: set EMAIL_HOST=smtp.gmail.com, EMAIL_USER=you@gmail.com, EMAIL_PASS=your_app_password
# Use any SMTP provider (Resend, Brevo, Postmark, etc.)
# If EMAIL_USER or EMAIL_PASS are blank, email sending is disabled (a warning is logged)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=PrepMate <noreply@prepmate.com>
SUPPORT_EMAIL=support@prepmate.com

# Optional: Rate Limiting
# RATE_LIMIT_TTL=60
# RATE_LIMIT_MAX=100

# Razorpay Payment (Phase 1 & 2)
# Get keys from Razorpay Dashboard → Settings → API Keys
# Use test keys (rzp_test_*) during development
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
